{
  "name": "brinka-app-nativa-extremo",
  "version": "1.0.0",
  "description": "Brinka Desktop - App Nativa Extremo",
  "main": "main.js",
  "author": "Brinka",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.brinka.nativa.extremo",
    "productName": "Brinka",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "splash.html",
      "package.json",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/brinka-logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Brinka"
    }
  }
}